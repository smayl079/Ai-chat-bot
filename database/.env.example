# Database Connection Configuration

# PostgreSQL Connection String
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:your_password_here@localhost:5432/chatbot_platform"

# Alternative format (individual values)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatbot_platform
DB_USER=postgres
DB_PASSWORD=your_password_here

# Note: This is a template file
# Copy this to .env and update with your actual credentials
# Never commit .env with real credentials to version control
